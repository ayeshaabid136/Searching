#include <iostream>
using namespace std;

int l = 0;
int r = 9;
int mid;
int arr[5];

int binarySearch(int tosearch){
   while(l <= r){
    int mid = (l+r)/2;
    if(tosearch == arr[mid] ){
        return mid;
    }
    else if(tosearch > arr[mid]){
        r = mid + 1;
    }
    else if(tosearch < arr[mid]){
        l = mid - 1;
    }

    return tosearch;
  }
}



int main(){
    int n;
    cout<< "Enter Number of Elements of Array:";
    cin>> n;

    int arr[n];
    cout<< "Enter Array Elements: \n";
    for(int i=0; i<n; i++){
        cin>> arr[i];
    }

    int tosearch;
    cout << "Enter Value to Search: \n";
    cin>> tosearch;

    cout<< binarySearch(tosearch) <<endl;

}

