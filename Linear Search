#include <iostream>
using namespace std;
 
  void LinearSearch( int arr[], int tosearch){
    int flag = 0;
    for(int i=0; i<10; i++){
       if(arr[i] == tosearch){
        cout<< "Value Found at Index :" << i <<endl;
        flag = 1;
      }
   }
   if(flag == 0){
      cout<< "Value Not Found\n";
   }
}

int main(){

    int arr[10] = {77,65,12,34,10,43,82,2,3,7};

    int tosearch;
    cout<<"Enter value To search";
    cin>> tosearch;
    
    LinearSearch(arr, tosearch);
    return 0;
}
